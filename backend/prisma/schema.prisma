// smart-inventory/backend/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── User ──────────────────────────────────────────────────────────
model User {
  id            String    @id @default(uuid())
  email         String    @unique
  username      String    @unique
  password      String
  role          UserRole  @default(USER)
  balance       Float     @default(10000)   // Нийт баланс USD
  riskPerTrade  Float     @default(2)       // Нэг арилжааны эрсдэл %
  selectedPairs Json      @default("[\"EUR/USD\",\"GBP/USD\",\"USD/JPY\",\"USD/CHF\",\"AUD/USD\",\"EUR/GBP\",\"EUR/JPY\",\"XAU/USD\",\"XAG/USD\"]")
  riskRewardPresets Json  @default("[2,3]")
  subscription  Subscription?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  trades        Trade[]
  alerts        Alert[]
  strategies    Strategy[]
  aiAnalyses    AIAnalysis[]
  lessons       Lesson[]
  brokerConnections BrokerConnection[]

  @@map("users")
}

// ─── Trade (Арилжааны бүртгэл) ─────────────────────────────────────
model Trade {
  id            String      @id @default(uuid())
  userId        String

  pair          String      // e.g. "EUR/USD", "USD/JPY"
  direction     Direction   // BUY | SELL
  broker        String?
  brokerAccountId String?
  mt5Ticket     String?     @unique
  mt5OrderId    String?
  entryPrice    Float
  exitPrice     Float?
  lotSize       Float
  stopLoss      Float?
  takeProfit    Float?

  openedAt      DateTime
  closedAt      DateTime?
  status        TradeStatus @default(OPEN)

  pnl           Float?      // Ашиг алдагдал USD
  pnlPercent    Float?      // Ашиг алдагдал %
  commission    Float       @default(0)
  swap          Float       @default(0)
  currentPrice  Float?
  syncedAt      DateTime?

  strategyId    String?
  notes         String?
  entryReason   String?
  imageUrl      String?

  strategy      Strategy?   @relation(fields: [strategyId], references: [id])
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@map("trades")
  @@index([brokerAccountId])
  @@index([mt5OrderId])
}

model BrokerConnection {
  id                  String                  @id @default(uuid())
  userId              String
  broker              String
  brokerAccountId     String?
  maskedAccountNumber String
  server              String
  accountLogin        String?
  accountName         String?
  accountBalance      Float?
  accountEquity       Float?
  accountCurrency     String?
  accountLeverage     Int?
  apiTokenHash        String?                 @unique
  connectionType      BrokerConnectionType    @default(PASSWORD_BRIDGE)
  lastSyncedAt        DateTime?
  lastPingAt          DateTime?
  status              BrokerConnectionStatus  @default(WAITING)
  isActive            Boolean                 @default(false)
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  user                User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("broker_connections")
  @@index([userId])
}

// ─── Alert (Мэдэгдэл) ─────────────────────────────────────────────
model Alert {
  id            String      @id @default(uuid())
  userId        String

  pair          String
  alertType     AlertType
  targetPrice   Float
  currentPrice  Float?
  message       String?
  isTriggered   Boolean     @default(false)
  isActive      Boolean     @default(true)
  triggeredAt   DateTime?

  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@map("alerts")
}

// ─── Strategy (Стратеги) ───────────────────────────────────────────
model Strategy {
  id            String    @id @default(uuid())
  userId        String

  name          String
  description   String?
  rules         String?   // Арилжааны дүрмүүд
  timeframe     String?   // M1, M5, H1, D1...
  pairs         Json      // Ашигладаг валютын парууд

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  trades        Trade[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("strategies")
}

// ─── Subscription (AI захиалга) ─────────────────────────────────────
model Subscription {
  id            String            @id @default(uuid())
  userId        String            @unique

  plan          SubscriptionPlan
  status        SubscriptionStatus @default(ACTIVE)
  stripeId      String?           // Stripe subscription ID
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?

  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@map("subscriptions")
}

// ─── AI Analysis (AI шинжилгээ) ─────────────────────────────────────
model AIAnalysis {
  id              String         @id @default(uuid())
  userId          String

  type            AIAnalysisType
  title           String
  content         String         @db.Text
  imageUrl        String?        @db.Text
  tradeIds        Json?
  recommendations Json?

  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@map("ai_analyses")
}

// ─── Lesson (Өөрийгөө хөгжүүлэх видео хичээл) ────────────────────────
model Lesson {
  id            String      @id @default(uuid())
  authorId      String?

  title         String
  description   String?     @db.Text
  videoUrl      String      @db.Text
  thumbnailUrl  String?     @db.Text
  level         LessonLevel @default(BEGINNER)
  isPremium     Boolean     @default(false)
  duration      String?
  sortOrder     Int         @default(0)
  isPublished   Boolean     @default(true)

  author        User?       @relation(fields: [authorId], references: [id], onDelete: SetNull)

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@map("lessons")
}

// ─── Enums ─────────────────────────────────────────────────────────
enum Direction {
  BUY
  SELL
}

enum TradeStatus {
  OPEN
  CLOSED
  CANCELLED
}

enum AlertType {
  PRICE_ABOVE    // Үнэ дээш гарахад
  PRICE_BELOW    // Үнэ доош унахад
  STOP_LOSS      // Stop loss хүрэхэд
  TAKE_PROFIT    // Take profit хүрэхэд
}

enum SubscriptionPlan {
  BASIC     // Сар бүр 10 шинжилгээ
  PRO       // Сар бүр 50 шинжилгээ
  PREMIUM   // Хязгааргүй шинжилгээ
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
  UNPAID
}

enum AIAnalysisType {
  TRADE_ANALYSIS    // Арилжааны шинжилгээ
  CHART_ANALYSIS    // Чартын шинжилгээ
}

enum LessonLevel {
  BEGINNER
  ADVANCED
}

enum BrokerConnectionType {
  PASSWORD_BRIDGE
  MT5_EA
}

enum BrokerConnectionStatus {
  WAITING
  CONNECTED
  DISCONNECTED
  ERROR
  DISABLED
}

enum UserRole {
  USER
  ADMIN
}
